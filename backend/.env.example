# Ringg AI
RINGG_API_KEY=your-api-key
RINGG_AGENT_ID=your-agent-id
RINGG_FROM_NUMBER_ID=your-from-number-id

# Public URL (Railway gives you this)
PUBLIC_URL=https://raktsetu-backend-production.up.railway.app

# AWS Bedrock (Claude Haiku for extraction)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=us-east-1

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Security
WEBHOOK_SECRET=your-webhook-secret
SAFE_NUMBERS=7259702969

# Port
PORT=3001
